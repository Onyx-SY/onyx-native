{
  "program_info": {
    "name": "Onyx-Native",
    "version": "2.9.0.a1",
    "author": "脉动大羊",
    "tool_main_dir_name": "tools"
  },
  "display_info": {
    "welcome_title": "Welcome to Onyx",
    "default_color": 1,
    "command_prompts": {
      "def": "{user}@{mode_per}-{host}:{GREEN}{relative_path}{venv_git}{RESET} {permission} ",
      "skali": "\n{BLUE}╭──({RED}{user}@{mode_per}-{host}{BLUE})-[{RESET}{relative_path}{venv_git}{BLUE}]\n{BLUE}╰─{BLUE}{RED}{permission}: ",
      "ubuntu": "{user}@{host}:{relative_path}{venv_git} {permission} ",
      "terminal": "Termial>>> {venv_git}",
      "kali": "{BLUE}┌──({RED}{user}㉿{host}-{mode_per}{BLUE})-[{RESET}{relative_path}{venv_git}{BLUE}]\n{BLUE}└─{BLUE}{RED}{permission} {RESET}",
      "termux": "{GREEN}{relative_path}{venv_git} {RESET}{permission} ",
      "onyx": "{BLUE}╭──<{RESET}{RED}{user}@{host}-{mode_TS}{BLUE}>-({YELLOW}{mode_per}{BLUE})-[{RESET}{relative_path}{venv_git}{BLUE}]\n{BLUE}╰─{BLUE}{RED}{permission}{RESET} {accent} >{accent_reset} ",
      "zsh": "{host} {relative_path}{venv_git} {permission} ",
      "ohmyzsh": "{accent}➜{accent_reset}  {BLUE}{relative_path}{RESET} {YELLOW}{venv_git}{RESET} ",
      "pure": "{BLUE}{relative_path}{RESET} {YELLOW}{venv_git}{RESET} {exit_mark}\n{permission} "
    },
    "language": {
      "default": "Chinese",
      "support": [
        "Chinese",
        "English"
      ],
      "current": "english"
    },
    "error_hint": {
      "no_command": "No command '{cmd}' found",
      "tool_suggest": "",
      "system_cmd_suggest": ""
    }
  },
  "system_info": {
    "max_history_len": 10000,
    "current_prompt_type": "onyx"
  },
  "tool_category_dirs": [
    "sys_tools",
    "download",
    "plugin"
  ],
  "ui_config": {
    "file_operations": {
      "max_file_size": 104857600
    }
  },
  "security": {
    "enable": true,
    "max_process_count": 5,
    "log_path": "onyxlog/onyx/.onyx_security.log",
    "guard_mode": {
      "enable_default": false,
      "risk_level_map": {
        "1": "low",
        "2": "low",
        "3": "mid",
        "4": "mid",
        "5": "adv"
      },
      "auto_stop_level": 3,
      "log_path": "onyxlog/onyx/.onyx_guard.log"
    }
  },
  "user_config": {
    "save_history": true,
    "auto_load_user_config": true,
    "default_mode": "low",
    "default_tool_perm": 3,
    "enable_autocmd": true
  },
  "log_config": {
    "log_level": "INFO",
    "log_rotation_size": 10485760
  },
  "sys_specific": {
    "quick_alias": {},
    "tool_config_rule": {
      "config_file": "config.conf",
      "fields": {
        "author": "author = ",
        "name": "name = ",
        "version": "version = ",
        "cli": "cli = ",
        "type": "type = ",
        "introduction": "introduction = "
      }
    },
    "perm_file": ".perm"
  },
  "mode_config": {
    "levels": [
      "low",
      "mid",
      "adv"
    ],
    "activite_cmd": {
      "param_m": "mode",
      "param_t": "tool_perm",
      "adv_password_required": true
    }
  }
}