{
  "_config": {
    "allow_advanced_syntax": true
  },

  "/dev/<*:10>": {
    "mode": "blacklist",
    "allow_advanced_syntax": true,
    "commands": [
      "rm", "dd", "dcfldd",
      "mkfs", "mkfs.ext4", "mkfs.vfat", "mkfs.ntfs", "mkfs.xfs",
      "fdisk", "parted", "gdisk", "sgdisk", "cfdisk", "cgdisk", "sfdisk",
      "wipefs", "shred", "blkdiscard",
      "nvme", "hdparm", "sg_format", "badblocks",
      "mkswap", "cryptsetup",
      "pvremove", "pvcreate", "vgremove", "vgcreate", "lvremove", "lvcreate",
      "mdadm", "dmsetup", "blockdev",
      "tune2fs", "xfs_repair", "debugfs", "btrfs",
      "chmod", "chown", "mv"
    ]
  },

  "/boot/<*:10>": {
    "mode": "whitelist",
    "allow_advanced_syntax": false,
    "commands": ["ls", "cd", "cat", "grep", "less", "stat", "file"]
  },

  "/etc/<*:10>": {
    "mode": "whitelist",
    "allow_advanced_syntax": false,
    "commands": ["ls", "cd", "cat", "grep", "less", "more", "head", "tail", "diff", "stat", "file"]
  },
  "/root/<*:10>": {
    "mode": "whitelist",
    "allow_advanced_syntax": false,
    "commands": ["ls", "cd", "cat", "grep", "less", "head", "tail", "stat"]
  },
  "/home/<other>/<*:10>": {
    "mode": "whitelist",
    "allow_advanced_syntax": false,
    "commands": ["ls", "cd", "cat", "grep", "less", "head", "tail", "stat", "file"]
  },
  "/home/<username>/<*:10>": {
    "mode": "blacklist",
    "allow_advanced_syntax": true,
    "commands": [
      "mkfs", "fdisk", "parted", "gdisk", "sgdisk",
      "dd", "dcfldd",
      "wipefs", "shred", "blkdiscard",
      "mkswap", "cryptsetup",
      "pvremove", "pvcreate", "vgremove", "vgcreate", "lvremove", "lvcreate",
      "mdadm", "dmsetup"
    ]
  },

  "/sys/<*:10>": {
